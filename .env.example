# ──────────────────────────────────────────────
# Application configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── Postgres ──────────────────────────────────
# asyncpg DSN used by the app at runtime
DATABASE_URL=postgresql://postgres:changeme@db:5432/myapp

# DSN used by pytest (can point to a separate test schema/database)
TEST_DATABASE_URL=postgresql://postgres:changeme@localhost:5432/myapp_test

# ── Application ───────────────────────────────
APP_ENV=development          # development | staging | production
SECRET_KEY=replace-me-with-a-long-random-string
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
